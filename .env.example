# ── SHUVO BOT — Environment Variables ──
# Copy this file to .env and fill in your values
# Railway তে এগুলো Variables section এ add করবে

# ── Required ──
BOT_TOKEN=your_main_bot_token_here
CONTROLLER_TOKEN=your_controller_bot_token_here
ADMIN_ID=your_telegram_user_id_here
OWNER_ID=your_telegram_user_id_here

# ── Optional: Group/Channel ──
REQUIRED_GROUP=@YourChannelUsername

# ── Optional: APIs (defaults already set) ──
NASA_API_KEY=DEMO_KEY
GITHUB_TOKEN=your_github_token_here
GROQ_API_KEY=no-key-needed
GROQ_MODEL=openai-fast
GROQ_API_BASE=https://text.pollinations.ai/openai
POLLINATIONS_BASE=https://image.pollinations.ai/prompt

# ── Optional: Voice Chat Credentials ──
VC_API_ID=your_api_id
VC_API_HASH=your_api_hash
VC_SESSION=your_pyrogram_session_string
